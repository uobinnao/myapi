    "/foods": {
      "get": {
        "tags": [
          "foods"
        ],
        "summary": "Search foods",
        "description": "Search USDA FoodData Central by food type and return normalized results.",
        "operationId": "search_foods_foods_get",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "minLength": 1,
              "maxLength": 100,
              "pattern": "^[a-zA-Z0-9\\s\\-_]+$",
              "description": "Food type to search for (e.g. \"apple\", \"chicken breast\")",
              "title": "Type"
            },
            "description": "Food type to search for (e.g. \"apple\", \"chicken breast\")",
            "examples": {
              "apple": {
                "summary": "Simple search",
                "value": "apple"
              },
              "protein": {
                "summary": "Protein source",
                "value": "chicken breast"
              }
            }
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "maximum": 50,
              "minimum": 1,
              "description": "Maximum number of results to return (1-50, default: 10)",
              "default": 10,
              "title": "Limit"
            },
            "description": "Maximum number of results to return (1-50, default: 10)",
            "examples": {
              "default": {
                "summary": "Default result size",
                "value": 10
              },
              "small": {
                "summary": "Small result set",
                "value": 5
              }
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Normalized food search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FoodsResponse"
                }
              }
            }
          },
          "400": {
            "content": {
              "application/problem+json": {},
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Bad request"
          },
          "401": {
            "content": {
              "application/problem+json": {},
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Unauthorized"
          },
          "403": {
            "content": {
              "application/problem+json": {},
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Forbidden"
          },
          "404": {
            "content": {
              "application/problem+json": {},
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Not found"
          },
          "405": {
            "content": {
              "application/problem+json": {},
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Method not allowed"
          },
          "422": {
            "content": {
              "application/problem+json": {},
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Request validation failed"
          },
          "429": {
            "content": {
              "application/problem+json": {},
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Too many requests"
          },
          "500": {
            "content": {
              "application/problem+json": {},
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Internal server error"
          },
          "502": {
            "content": {
              "application/problem+json": {},
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Bad gateway"
          },
          "503": {
            "content": {
              "application/problem+json": {},
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            },
            "description": "Service unavailable"
          }
        },
        "x-rateLimiting": {
          "windowMs": "15 minutes",
          "maxRequests": 100,
          "description": "Rate limited to 100 requests per IP address per 15-minute window"
        }
      }
    }
  },
