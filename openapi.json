{
  "openapi": "3.1.0",
  "info": {
    "title": "Food API",
    "summary": "Search USDA FoodData Central foods",
    "description": "FastAPI service that proxies USDA FoodData Central food search.",
    "version": "1.0.0"
  },
  "paths": {
    "/": {
      "get": {
        "tags": [
          "meta"
        ],
        "summary": "Get API info",
        "description": "Return service metadata, documentation links, and the list of available endpoints.",
        "operationId": "get_api_info__get",
        "responses": {
          "200": {
            "description": "API metadata and endpoint catalog",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiInfo"
                }
              }
            }
          },
          "429": {
            "description": "Too many requests",
            "content": {
              "application/problem+json": {},
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/problem+json": {},
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetail"
                }
              }
            }
          }
        }
      }
    },
    "/health/live": {
      "get": {
        "tags": [
          "meta"
        ],
        "summary": "Get liveness status",
        "description": "Cheap liveness probe that only confirms the app process is running.",
        "operationId": "get_live_health_live_get",
        "responses": {
          "200": {
            "description": "Liveness probe result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProbeResponse"
